.video-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(350px,1fr));gap:25px;margin:25px 0}
.video-card{background:#2a2a2a;border-radius:15px;overflow:hidden;transition:transform 0.3s;border:2px solid transparent}
.video-card:hover{transform:translateY(-5px);border-color:#f7931a;box-shadow:0 10px 30px rgba(247,147,26,0.3)}
.video-wrapper{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;background:#000}
.video-wrapper iframe,.video-wrapper video{position:absolute;top:0;left:0;width:100%;height:100%;border:0}
.video-info{padding:20px}
.video-info h3{color:#f7931a;margin-bottom:10px}
.song-list{display:grid;gap:15px;margin:25px 0}
.song-item{background:linear-gradient(90deg,#2a2a2a,#1a1a1a);padding:20px;border-radius:12px;display:flex;align-items:center;justify-content:space-between;border-left:4px solid #f7931a;transition:all 0.3s}
.song-item:hover{background:linear-gradient(90deg,#3a3a3a,#2a2a2a);transform:translateX(5px)}
.song-info{flex:1}
.song-info h4{color:#f7931a;font-size:1.2em;margin-bottom:5px}
.song-info p{font-size:0.9em;opacity:0.8}
.song-actions{display:flex;gap:10px}
.btn{background:linear-gradient(135deg,#f7931a,#ff9f1a);color:#000;border:none;padding:12px 25px;border-radius:25px;font-size:14px;font-weight:bold;cursor:pointer;text-decoration:none;display:inline-block;transition:all 0.3s}
.btn:hover{transform:scale(1.05);box-shadow:0 5px 20px rgba(247,147,26,0.5)}
.btn-play{background:linear-gradient(135deg,#1db954,#1ed760)}
.btn-buy{background:linear-gradient(135deg,#f7931a,#ff6b35)}
.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin:25px 0}
.card{background:#2a2a2a;padding:30px;border-radius:15px;text-align:center;transition:all 0.3s;border:2px solid transparent}
.card:hover{transform:translateY(-5px);border-color:#f7931a;box-shadow:0 10px 30px rgba(247,147,26,0.3)}
.price{font-size:2.2em;color:#f7931a;font-weight:bold;margin:15px 0}
.affiliate-section{background:linear-gradient(135deg,rgba(247,147,26,0.2),rgba(247,147,26,0.05));border:3px solid #f7931a;padding:40px;border-radius:20px;margin:30px 0}
.affiliate-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:15px;margin:20px 0}
.affiliate-link{background:rgba(42,42,42,0.8);padding:15px;border-radius:12px;text-align:center;text-decoration:none;color:#fff;display:block;transition:all 0.3s;border:2px solid rgba(247,147,26,0.3)}
.affiliate-link:hover{background:rgba(247,147,26,0.2);border-color:#f7931a;transform:translateY(-3px)}
.affiliate-link .ref-code{display:block;font-size:11px;color:#f7931a;margin-top:8px;font-family:monospace}
.wallet{background:#2a2a2a;padding:25px;border-radius:15px;margin:20px 0;border:3px solid #f7931a}
.wallet-addr{font-family:monospace;font-size:14px;word-break:break-all;color:#f7931a;margin:15px 0;padding:15px;background:#1a1a1a;border-radius:8px}
.alert-box{background:rgba(247,147,26,0.2);border:2px solid #f7931a;border-radius:15px;padding:25px;margin:25px 0;text-align:center}
@media(max-width:768px){
.header h1{font-size:2em}
.video-grid,.grid,.affiliate-grid{grid-template-columns:1fr}
}
</style>
</head>
