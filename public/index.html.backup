<script>
// Movie channel playlists
const movieChannels = [
  {name: 'Osamu Ellvitor', id: 'UCosamuellvitor', videos: ['dQw4w9WgXcQ','jNQXAC9IVRw','9bZkp7q19f0']},
  {name: 'Sednem21', id: 'UCsednem21', videos: ['dQw4w9WgXcQ','jNQXAC9IVRw','9bZkp7q19f0']},
  {name: 'Skyline Ventures', id: 'UCskylineventures', videos: ['dQw4w9WgXcQ','jNQXAC9IVRw','9bZkp7q19f0']}
];

// Random movie loader
function loadRandomMovie(slot) {
  const channel = movieChannels[Math.floor(Math.random() * movieChannels.length)];
  const videoId = channel.videos[Math.floor(Math.random() * channel.videos.length)];
  const iframe = `<iframe src="https://www.youtube.com/embed/${videoId}?autoplay=1" style="width:100%;height:100%;border:0" allowfullscreen allow="autoplay"></iframe>`;
  document.getElementById('randomMovie' + slot).innerHTML = iframe;
}

// Load random movies on page load
window.addEventListener('load', () => {
  loadRandomMovie(1);
  loadRandomMovie(2);
  loadRandomMovie(3);
  
  // Auto-rotate movies every 5 minutes
  setInterval(() => {
    loadRandomMovie(Math.floor(Math.random() * 3) + 1);
  }, 5 * 60 * 1000);
});
</script>
