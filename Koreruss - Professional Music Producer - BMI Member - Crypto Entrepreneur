.container { max-width: 1400px; margin: 0px auto; padding: 20px; }

.header { background: linear-gradient(135deg, rgb(102, 126, 234), rgb(118, 75, 162)); padding: 60px 20px; text-align: center; border-radius: 20px; margin-bottom: 30px; box-shadow: rgba(0, 0, 0, 0.5) 0px 10px 40px; }

