.video-info { padding: 20px; }

.video-info h3 { color: rgb(247, 147, 26); margin-bottom: 10px; }

.song-list { display: grid; gap: 15px; margin: 25px 0px; }

.song-item { background: linear-gradient(90deg, rgb(42, 42, 42), rgb(26, 26, 26)); padding: 20px; border-radius: 12px; display: flex; align-items: center; justify-content: space-between; border-left: 4px solid rgb(247, 147, 26); transition: 0.3s; }

.song-item:hover { background: linear-gradient(90deg, rgb(58, 58, 58), rgb(42, 42, 42)); transform: translateX(5px); }

.song-info { flex: 1 1 0%; }

.song-info h4 { color: rgb(247, 147, 26); font-size: 1.2em; margin-bottom: 5px; }

.song-info p { font-size: 0.9em; opacity: 0.8; }

.song-actions { display: flex; gap: 10px; }

.btn { background: linear-gradient(135deg, rgb(247, 147, 26), rgb(255, 159, 26)); color: rgb(0, 0, 0); border: none; padding: 12px 25px; border-radius: 25px; font-size: 14px; font-weight: bold; cursor: pointer; text-decoration: none; display: inline-block; transition: 0.3s; }

.btn:hover { transform: scale(1.05); box-shadow: rgba(247, 147, 26, 0.5) 0px 5px 20px; }

.btn-play { background: linear-gradient(135deg, rgb(29, 185, 84), rgb(30, 215, 96)); }

.btn-buy { background: linear-gradient(135deg, rgb(247, 147, 26), rgb(255, 107, 53)); }

.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin: 25px 0px; }

.card { background: rgb(42, 42, 42); padding: 30px; border-radius: 15px; text-align: center; transition: 0.3s; border: 2px solid transparent; }

.card:hover { transform: translateY(-5px); border-color: rgb(247, 147, 26); box-shadow: rgba(247, 147, 26, 0.3) 0px 10px 30px; }

.price { font-size: 2.2em; color: rgb(247, 147, 26); font-weight: bold; margin: 15px 0px; }

.affiliate-section { background: linear-gradient(135deg, rgba(247, 147, 26, 0.2), rgba(247, 147, 26, 0.05)); border: 3px solid rgb(247, 147, 26); padding: 40px; border-radius: 20px; margin: 30px 0px; }

.affiliate-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; margin: 20px 0px; }

.affiliate-link { background: rgba(42, 42, 42, 0.8); padding: 15px; border-radius: 12px; text-align: center; text-decoration: none; color: rgb(255, 255, 255); display: block; transition: 0.3s; border: 2px solid rgba(247, 147, 26, 0.3); }

.affiliate-link:hover { background: rgba(247, 147, 26, 0.2); border-color: rgb(247, 147, 26); transform: translateY(-3px); }

.affiliate-link .ref-code { display: block; font-size: 11px; color: rgb(247, 147, 26); margin-top: 8px; font-family: monospace; }

.wallet { background: rgb(42, 42, 42); padding: 25px; border-radius: 15px; margin: 20px 0px; border: 3px solid rgb(247, 147, 26); }

.wallet-addr { font-family: monospace; font-size: 14px; word-break: break-all; color: rgb(247, 147, 26); margin: 15px 0px; padding: 15px; background: rgb(26, 26, 26); border-radius: 8px; }

.alert-box { background: rgba(247, 147, 26, 0.2); border: 2px solid rgb(247, 147, 26); border-radius: 15px; padding: 25px; margin: 25px 0px; text-align: center; }

@media (max-width: 768px) {
  .header h1 { font-size: 2em; }
  .video-grid, .grid, .affiliate-grid { grid-template-columns: 1fr; }
}
